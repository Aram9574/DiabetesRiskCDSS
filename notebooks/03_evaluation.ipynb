{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 — Model Training, Evaluation & Explainability\n",
    "## Diabetes Risk Prediction · Clinical ML Portfolio\n",
    "\n",
    "Three models compared: Logistic Regression, SVM (RBF), Random Forest.  \n",
    "Evaluation includes AUC-ROC, calibration, clinical metrics, and SHAP explainability.  \n",
    "Final model serialized for Streamlit deployment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import shap\n",
    "import joblib\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score, GridSearchCV\n",
    "from sklearn.metrics import (\n",
    "    roc_auc_score, roc_curve, accuracy_score,\n",
    "    classification_report, confusion_matrix,\n",
    "    brier_score_loss, ConfusionMatrixDisplay\n",
    ")\n",
    "from sklearn.calibration import calibration_curve, CalibratedClassifierCV\n",
    "\n",
    "sns.set_theme(style='whitegrid')\n",
    "plt.rcParams['figure.dpi'] = 120\n",
    "\n",
    "print('Libraries loaded OK')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train = pd.read_csv('../data/X_train.csv')\n",
    "X_test  = pd.read_csv('../data/X_test.csv')\n",
    "X_train_sc = pd.read_csv('../data/X_train_scaled.csv')\n",
    "X_test_sc  = pd.read_csv('../data/X_test_scaled.csv')\n",
    "y_train = pd.read_csv('../data/y_train.csv').squeeze()\n",
    "y_test  = pd.read_csv('../data/y_test.csv').squeeze()\n",
    "\n",
    "print(f'Train: {X_train.shape}, Test: {X_test.shape}')\n",
    "print(f'Positive rate — Train: {y_train.mean():.3f}, Test: {y_test.mean():.3f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Cross-Validation — Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "\n",
    "models = {\n",
    "    'Logistic Regression': (LogisticRegression(class_weight='balanced', max_iter=1000, random_state=42), X_train_sc),\n",
    "    'SVM (RBF)':           (SVC(kernel='rbf', class_weight='balanced', probability=True, random_state=42), X_train_sc),\n",
    "    'Random Forest':       (RandomForestClassifier(n_estimators=100, class_weight='balanced', random_state=42), X_train),\n",
    "}\n",
    "\n",
    "cv_results = {}\n",
    "print('5-Fold CV AUC-ROC:')\n",
    "print('-' * 45)\n",
    "for name, (model, X) in models.items():\n",
    "    scores = cross_val_score(model, X, y_train, cv=cv, scoring='roc_auc')\n",
    "    cv_results[name] = scores\n",
    "    print(f'  {name:<22} {scores.mean():.4f} ± {scores.std():.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Hyperparameter Tuning — Random Forest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "param_grid = {\n",
    "    'n_estimators': [100, 200],\n",
    "    'max_depth': [None, 10, 20],\n",
    "    'min_samples_split': [2, 5],\n",
    "    'min_samples_leaf': [1, 2],\n",
    "}\n",
    "\n",
    "rf_base = RandomForestClassifier(class_weight='balanced', random_state=42)\n",
    "grid_search = GridSearchCV(rf_base, param_grid, cv=cv, scoring='roc_auc', n_jobs=-1, verbose=0)\n",
    "grid_search.fit(X_train, y_train)\n",
    "\n",
    "print(f'Best params: {grid_search.best_params_}')\n",
    "print(f'Best CV AUC-ROC: {grid_search.best_score_:.4f}')\n",
    "\n",
    "best_rf = grid_search.best_estimator_"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Final Evaluation on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train all models on full training set\n",
    "lr = LogisticRegression(class_weight='balanced', max_iter=1000, random_state=42)\n",
    "svm = SVC(kernel='rbf', class_weight='balanced', probability=True, random_state=42)\n",
    "\n",
    "lr.fit(X_train_sc, y_train)\n",
    "svm.fit(X_train_sc, y_train)\n",
    "best_rf.fit(X_train, y_train)\n",
    "\n",
    "final_models = {\n",
    "    'Logistic Regression': (lr, X_test_sc),\n",
    "    'SVM (RBF)': (svm, X_test_sc),\n",
    "    'Random Forest': (best_rf, X_test),\n",
    "}\n",
    "\n",
    "results = {}\n",
    "print(f'{\"Model\":<22} {\"AUC-ROC\":>8} {\"Accuracy\":>9} {\"Sensitivity\":>12} {\"Specificity\":>12} {\"Brier\":>7}')\n",
    "print('-' * 75)\n",
    "\n",
    "for name, (model, X) in final_models.items():\n",
    "    y_prob = model.predict_proba(X)[:, 1]\n",
    "    y_pred = model.predict(X)\n",
    "    \n",
    "    tn, fp, fn, tp = confusion_matrix(y_test, y_pred).ravel()\n",
    "    sensitivity = tp / (tp + fn)\n",
    "    specificity = tn / (tn + fp)\n",
    "    auc = roc_auc_score(y_test, y_prob)\n",
    "    acc = accuracy_score(y_test, y_pred)\n",
    "    brier = brier_score_loss(y_test, y_prob)\n",
    "    \n",
    "    results[name] = {\n",
    "        'model': model, 'X_test': X,\n",
    "        'y_prob': y_prob, 'y_pred': y_pred,\n",
    "        'auc': auc, 'accuracy': acc,\n",
    "        'sensitivity': sensitivity, 'specificity': specificity,\n",
    "        'brier': brier\n",
    "    }\n",
    "    print(f'{name:<22} {auc:>8.4f} {acc:>9.4f} {sensitivity:>12.4f} {specificity:>12.4f} {brier:>7.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. ROC Curves Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "colors = ['#4C72B0', '#DD8452', '#55A868']\n",
    "\n",
    "for (name, res), color in zip(results.items(), colors):\n",
    "    fpr, tpr, _ = roc_curve(y_test, res['y_prob'])\n",
    "    ax.plot(fpr, tpr, color=color, lw=2, label=f\"{name} (AUC = {res['auc']:.3f})\")\n",
    "\n",
    "ax.plot([0,1], [0,1], 'k--', lw=1, alpha=0.5, label='Random classifier')\n",
    "ax.set_xlabel('False Positive Rate (1 - Specificity)')\n",
    "ax.set_ylabel('True Positive Rate (Sensitivity)')\n",
    "ax.set_title('ROC Curves — Model Comparison', fontsize=13, fontweight='bold')\n",
    "ax.legend(loc='lower right')\n",
    "ax.set_xlim([0, 1])\n",
    "ax.set_ylim([0, 1.02])\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/roc_curves.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('Clinical note: In a screening context, we prioritize sensitivity (minimize false negatives).')\n",
    "print('A missed diabetes diagnosis carries higher clinical cost than a false alarm.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Calibration Curves\n",
    "\n",
    "A well-calibrated model means: when it predicts 70% probability, ~70% of those patients actually have diabetes. Calibration matters clinically — poorly calibrated probabilities mislead clinical decision-making."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "colors = ['#4C72B0', '#DD8452', '#55A868']\n",
    "\n",
    "ax.plot([0,1], [0,1], 'k--', lw=1, alpha=0.5, label='Perfect calibration')\n",
    "\n",
    "for (name, res), color in zip(results.items(), colors):\n",
    "    prob_true, prob_pred = calibration_curve(y_test, res['y_prob'], n_bins=8)\n",
    "    ax.plot(prob_pred, prob_true, 's-', color=color, lw=2,\n",
    "            label=f\"{name} (Brier = {res['brier']:.3f})\")\n",
    "\n",
    "ax.set_xlabel('Mean Predicted Probability')\n",
    "ax.set_ylabel('Fraction of Positives')\n",
    "ax.set_title('Calibration Curves', fontsize=13, fontweight='bold')\n",
    "ax.legend(loc='upper left')\n",
    "ax.set_xlim([0, 1])\n",
    "ax.set_ylim([0, 1])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('Brier score: lower is better (0 = perfect, 0.25 = no-skill classifier)')\n",
    "print('→ Random Forest shows best calibration alongside highest AUC.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. SHAP Explainability — Random Forest\n",
    "\n",
    "SHAP (SHapley Additive exPlanations) quantifies the contribution of each feature to each prediction. Essential for clinical ML: a clinician needs to understand *why* a model flagged a patient, not just that it did."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Global SHAP — feature importance across all test patients\n",
    "explainer = shap.TreeExplainer(best_rf)\n",
    "shap_values = explainer.shap_values(X_test)\n",
    "\n",
    "# For binary classification, shap_values is a list [class0, class1]\n",
    "# We take class 1 (diabetes positive)\n",
    "if isinstance(shap_values, list):\n",
    "    sv = shap_values[1]\n",
    "else:\n",
    "    sv = shap_values\n",
    "\n",
    "print('Global SHAP Summary — Feature Importance (Diabetes class):')\n",
    "feature_importance = pd.DataFrame({\n",
    "    'feature': X_test.columns,\n",
    "    'mean_abs_shap': np.abs(sv).mean(axis=0)\n",
    "}).sort_values('mean_abs_shap', ascending=False)\n",
    "\n",
    "print(feature_importance.to_string(index=False))\n",
    "\n",
    "print('\\nClinical interpretation:')\n",
    "print('  Glucose: dominant predictor — aligns with its role as diagnostic criterion (ADA)')\n",
    "print('  BMI: second most important — consistent with T2D pathophysiology (obesity → IR)')\n",
    "print('  Age: increasing risk with age — well-established epidemiological relationship')\n",
    "print('  DiabetesPedigreeFunction: genetic risk captured by family history proxy')\n",
    "print('  Insulin: high missingness may explain lower-than-expected importance')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SHAP Summary Plot (beeswarm)\n",
    "fig, ax = plt.subplots(figsize=(9, 6))\n",
    "shap.summary_plot(sv, X_test, plot_type='dot', show=False, max_display=8)\n",
    "plt.title('SHAP Feature Impact — Random Forest (Diabetes class)', fontsize=12, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/shap_summary.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Local SHAP — single patient explanation\n",
    "# Pick a high-risk patient for illustration\n",
    "high_risk_idx = results['Random Forest']['y_prob'].argmax()\n",
    "patient = X_test.iloc[[high_risk_idx]]\n",
    "prob = results['Random Forest']['y_prob'][high_risk_idx]\n",
    "\n",
    "print(f'Example patient (highest predicted risk):')\n",
    "print(patient.T.rename(columns={patient.index[0]: 'Value'}))\n",
    "print(f'\\nPredicted probability of diabetes: {prob:.1%}')\n",
    "print(f'Actual outcome: {\"Diabetes\" if y_test.iloc[high_risk_idx] == 1 else \"No diabetes\"}')\n",
    "\n",
    "print('\\nSHAP local explanation — which features drove this prediction?')\n",
    "local_shap = pd.DataFrame({\n",
    "    'feature': X_test.columns,\n",
    "    'value': patient.values[0],\n",
    "    'shap_contribution': sv[high_risk_idx]\n",
    "}).sort_values('shap_contribution', ascending=False)\n",
    "print(local_shap.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Threshold Analysis — Clinical Operating Point\n",
    "\n",
    "Default threshold (0.5) is not always optimal clinically. In diabetes screening, we may accept lower specificity to maximize sensitivity — catching more at-risk patients."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y_prob_rf = results['Random Forest']['y_prob']\n",
    "fpr, tpr, thresholds = roc_curve(y_test, y_prob_rf)\n",
    "\n",
    "threshold_df = pd.DataFrame({\n",
    "    'threshold': thresholds,\n",
    "    'sensitivity': tpr,\n",
    "    'specificity': 1 - fpr\n",
    "})\n",
    "\n",
    "# Find threshold maximizing sensitivity while keeping specificity > 0.65\n",
    "clinical_threshold = threshold_df[\n",
    "    threshold_df['specificity'] >= 0.65\n",
    "].sort_values('sensitivity', ascending=False).iloc[0]\n",
    "\n",
    "print(f'Standard threshold (0.5):')\n",
    "y_pred_05 = (y_prob_rf >= 0.5).astype(int)\n",
    "tn,fp,fn,tp = confusion_matrix(y_test, y_pred_05).ravel()\n",
    "print(f'  Sensitivity: {tp/(tp+fn):.3f} | Specificity: {tn/(tn+fp):.3f}')\n",
    "\n",
    "print(f'\\nClinically-oriented threshold ({clinical_threshold[\"threshold\"]:.2f}):')\n",
    "y_pred_opt = (y_prob_rf >= clinical_threshold['threshold']).astype(int)\n",
    "tn,fp,fn,tp = confusion_matrix(y_test, y_pred_opt).ravel()\n",
    "print(f'  Sensitivity: {tp/(tp+fn):.3f} | Specificity: {tn/(tn+fp):.3f}')\n",
    "print(f'  Trade-off: more true positives caught, more false alarms to follow up')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Save Final Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "joblib.dump(best_rf, '../src/model_rf.pkl')\n",
    "joblib.dump(explainer, '../src/shap_explainer.pkl')\n",
    "\n",
    "# Save feature names for app\n",
    "feature_names = list(X_train.columns)\n",
    "joblib.dump(feature_names, '../src/feature_names.pkl')\n",
    "\n",
    "print('Model artifacts saved:')\n",
    "print('  src/model_rf.pkl')\n",
    "print('  src/shap_explainer.pkl')\n",
    "print('  src/feature_names.pkl')\n",
    "print(f'\\nFinal model AUC-ROC: {results[\"Random Forest\"][\"auc\"]:.4f}')\n",
    "print(f'Final model accuracy: {results[\"Random Forest\"][\"accuracy\"]:.4f}')\n",
    "print('\\n→ Proceed to app/streamlit_app.py for deployment')"
   ]
  }
 ],
